{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "**",
      "!build/",
      "!.svelte-kit/",
      "!dist/",
      "!node_modules/",
      "!vite.config.ts",
      "!svelte.config.js",
      "!scripts/"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 4,
    "lineWidth": 100,
    "lineEnding": "lf",
    "attributePosition": "auto"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSameLine": true
    }
  },
  "css": {
    "formatter": {
      "enabled": false
    },
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessConstructor": "warn",
        "noUselessSwitchCase": "warn",
        "noImportantStyles": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "off"
      },
      "style": {
        "useImportType": "error",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "error"
      },
      "nursery": {
        "useSortedClasses": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["*.md", "*.yml", "*.yaml", "*.toml", "*.json"],
      "formatter": {
        "indentWidth": 2
      }
    }
  ]
}
