{
  "name": "goatcolor",
  "description": "The only color picker palette generator you need.",
  "version": "2.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "eslint . --max-warnings=0 && svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "clean": "rm -rf build dist .context .svelte-kit node_modules .vitest coverage",
    "dev": "vite",
    "fix": "bun run lint -- --fix",
    "format": "prettier . --write",
    "health": "bun run check && bun run test && bun run build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "preview": "vite preview",
    "repo:back": "repomix -c .repomix/repomix.src.back.json",
    "repo:front": "repomix -c .repomix/repomix.src.front.json",
    "repo:full": "repomix -c .repomix/repomix.full.json",
    "repo:skel": "repomix -c .repomix/repomix.skel.json",
    "repo:src": "repomix -c .repomix/repomix.src.json",
    "repo:tool": "repomix -c .repomix/repomix.tool.json"
  },
  "dependencies": {
    "apca-w3": "^0.1.9",
    "color-name-list": "^14.32.0",
    "culori": "^4.0.2",
    "jspdf": "^4.2.0",
    "lucide-svelte": "^0.575.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/node": "^4.2.0",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/apca-w3": "^0.1.3",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.3.0",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.1",
    "svelte-check": "^4.4.3",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.7"
  },
  "lint-staged": {
    "*.{js,ts,mts,cts,jsx,tsx}": [
      "bun run eslint --fix",
      "bun run prettier --write"
    ],
    "*.svelte": [
      "bun run eslint --fix",
      "bun run prettier --write",
      "bun run svelte-check"
    ],
    "*.{css,scss,sass,less}": [
      "bun run prettier --write"
    ],
    "*.{md,mdx}": [
      "bun run prettier --write"
    ],
    "*.{json,jsonc,yaml,yml,toml}": [
      "bun run prettier --write"
    ],
    "*.html": [
      "bun run prettier --write"
    ],
    "package-lock.json": [
      "bun run prettier --write"
    ]
  },
  "trustedDependencies": [
    "core-js"
  ]
}
